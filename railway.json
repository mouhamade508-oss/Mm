{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "php artisan migrate:fresh --seed --force && vendor/bin/heroku-php-apache2 public/",
    "restartPolicy": {
      "type": "ON_FAILURE",
      "maxRetries": 3
    }
  }
}


